[global]
    monitor = 0
    follow = none

    # Position
    origin = top-right
    offset = 20x60
    
    # Size
    width = 340
    height = 200
    gap_size = 8

    # Appearance
    frame_width = 1
    frame_color = "#7aa2f7"
    corner_radius = 10
    transparency = 10

    # Font
    font = JetBrainsMono Nerd Font 11

    # Icon
    icon_position = left
    min_icon_size = 32
    max_icon_size = 48
    icon_theme = Papirus-Dark

    # Text
    alignment = left
    vertical_alignment = center
    word_wrap = yes
    markup = full
    format = "<b>%s</b>\n%b"

    # Behavior
    sort = yes
    indicate_hidden = yes
    show_age_threshold = 60
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    # Timeouts (in ms)
    sticky_history = yes
    history_length = 20

    # Mouse actions
    mouse_left_click = close_current
    mouse_right_click = close_all
    mouse_middle_click = do_action

    # Separator
    separator_height = 1
    separator_color = "#283457"
    padding = 12
    horizontal_padding = 14

[urgency_low]
    background = "#1a1b26"
    foreground = "#a9b1d6"
    frame_color = "#414868"
    timeout = 4

[urgency_normal]
    background = "#1a1b26"
    foreground = "#c0caf5"
    frame_color = "#7aa2f7"
    timeout = 6

[urgency_critical]
    background = "#1a1b26"
    foreground = "#f7768e"
    frame_color = "#f7768e"
    timeout = 0
